# mycoldmars — environment variables
#
# Copy to .env.local and fill in. .env.local is gitignored — never commit
# real values to .env.example or anywhere else.
#
# All VITE_-prefixed vars are bundled into the client. Treat them as
# public. Anything else is server-side only (Vercel Edge Functions, the
# transcode worker, local psql).
#
# See SECURITY.md for the full sensitivity tier per variable + the
# rotation procedure if any of them leak.

# ── Client (bundled, public-by-design) ─────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...                   # Supabase anon key (RLS enforced)

# ── Server: AI providers (api/* edge functions only) ───────────────
ANTHROPIC_API_KEY=sk-ant-...                        # Claude (translation, copilot, sot-hunter)
OPENAI_API_KEY=sk-proj-...                          # Whisper fallback transcription (25 MB cap)
DEEPGRAM_API_KEY=...                                # Preferred transcription (2 GB cap)
GEMINI_API_KEY=AIza...                              # Hunter scene insights, optional

# ── Server: Supabase admin (transcode worker + Hunter helpers) ─────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...                     # service_role JWT — server only, NEVER bundle
SUPABASE_DB_URL=postgresql://postgres:PW@db...      # direct DB url for migrations + worker

# ── Access gate ────────────────────────────────────────────────────
# Without this set, the gate runs in dev-mode (open). Set in production.
ACCESS_CODE=pick-something-not-easily-guessable

# ── Optional: Vercel build hooks / deploy keys (set in Vercel UI) ──
# VERCEL_TOKEN, VERCEL_ORG_ID, etc. — managed by Vercel CLI / dashboard.
